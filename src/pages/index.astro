---
import Base from '../layouts/Base.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'StoryArc Strategies',
  url: 'https://getstoryarc.com',
  logo: 'https://getstoryarc.com/logos/StoryArc_Black_Transparent.png',
  description: 'Narrative strategy for crypto and fintech companies. Content that builds authority, drives growth, and earns trust.',
  email: 'John@getstoryarc.com',
  areaServed: 'Worldwide',
  knowsAbout: ['Crypto Content Strategy', 'Fintech Content Marketing', 'Narrative Strategy', 'Positioning and Messaging', 'Thought Leadership'],
};
---

<Base
  title="Narrative Strategy for Crypto & Fintech | StoryArc Strategies"
  description="StoryArc Strategies is a narrative strategy firm for crypto and fintech companies. We create content that builds authority, drives growth, and earns trust."
  canonical="https://getstoryarc.com/"
  schema={schema}
>

<!-- ── HERO ── -->
<section id="hero">
  <div class="container">
    <h1 class="hero-h1">Narrative Strategy for Crypto &amp; Fintech Companies</h1>
    <p class="hero-sub">The market can't trust what it doesn't understand. StoryArc helps crypto and fintech companies communicate clearly — the kind of clarity that builds authority and drives real growth.</p>
    <a class="btn btn-accent" href="#contact">Work With Us</a>
  </div>
</section>

<!-- ── LOGO BAR ── -->
<section id="logos">
  <div class="logo-label">Worked with teams at:</div>
  <div class="logo-track-wrap">
    <div class="logo-track">
      <div class="logo-item"><img src="/logos/Coindesk.png" alt="CoinDesk" /></div>
      <div class="logo-item"><img src="/logos/Kraken.png" alt="Kraken" /></div>
      <div class="logo-item"><img src="/logos/Bitstamp.png" alt="Bitstamp" style="height:60px" /></div>
      <div class="logo-item"><img src="/logos/Babylon.svg" alt="Babylon" /></div>
      <div class="logo-item"><img src="/logos/Render NEtwork.svg" alt="Render Network" /></div>
      <div class="logo-item"><img src="/logos/milkroad.png" alt="Milk Road" style="height:64px" /></div>
      <div class="logo-item"><img src="/logos/unchained.png" alt="Unchained" style="filter: grayscale(1) invert(1) brightness(10);" /></div>
      <div class="logo-item"><img src="/logos/bitcointreasuries.net.svg" alt="Bitcoin Treasuries" /></div>
      <div class="logo-item"><img src="/logos/Let There Be.png" alt="Let There Be" style="height:90px" /></div>
      <div class="logo-item"><img src="/logos/Payward.png" alt="Payward" /></div>
      <div class="logo-item"><img src="/logos/xStocks.png" alt="xStocks" /></div>
      <!-- Duplicate for seamless loop -->
      <div class="logo-item"><img src="/logos/Coindesk.png" alt="CoinDesk" /></div>
      <div class="logo-item"><img src="/logos/Kraken.png" alt="Kraken" /></div>
      <div class="logo-item"><img src="/logos/Bitstamp.png" alt="Bitstamp" style="height:60px" /></div>
      <div class="logo-item"><img src="/logos/Babylon.svg" alt="Babylon" /></div>
      <div class="logo-item"><img src="/logos/Render NEtwork.svg" alt="Render Network" /></div>
      <div class="logo-item"><img src="/logos/milkroad.png" alt="Milk Road" style="height:64px" /></div>
      <div class="logo-item"><img src="/logos/unchained.png" alt="Unchained" style="filter: grayscale(1) invert(1) brightness(10);" /></div>
      <div class="logo-item"><img src="/logos/bitcointreasuries.net.svg" alt="Bitcoin Treasuries" /></div>
      <div class="logo-item"><img src="/logos/Let There Be.png" alt="Let There Be" style="height:90px" /></div>
      <div class="logo-item"><img src="/logos/Payward.png" alt="Payward" /></div>
      <div class="logo-item"><img src="/logos/xStocks.png" alt="xStocks" /></div>
    </div>
  </div>
</section>

<!-- ── PROBLEM ── -->
<section id="problem">
  <div class="container">
    <div class="section-label">The Problem</div>
    <h2 class="problem-heading">Smart companies get misunderstood all the time.</h2>
    <div class="problem-body">
      <p>Usually it's not because the product is weak.</p>
      <p>The issue is that the messaging starts sounding like every other company in the category. Generic claims. Abstract language. Big promises nobody remembers five minutes later.</p>
      <p>You see it a lot in technical industries. Founders spend years building something nuanced, then flatten it into marketing copy that could belong to almost anyone.</p>
      <p>That gap matters more than people think.</p>
    </div>
  </div>
</section>

<!-- ── SERVICES ── -->
<section id="services">
  <div class="container">
    <div class="section-label">Services</div>
    <h2 class="services-heading">What we do</h2>
    <p class="about-body" style="max-width:680px;margin-bottom:48px;">We help companies communicate more clearly, more consistently, and with a stronger point of view. Sometimes that means tightening positioning. Sometimes it means fixing a content system that's become noisy or disconnected. Sometimes it's helping a founder sound like an actual person again.<br /><br />The work changes. The goal usually doesn't.<br /><br />People need to understand what makes your company different before they can trust it.</p>
    <div class="services-grid">

      <div class="service-card">
        <div class="service-name">Positioning &amp; Messaging</div>
        <div class="service-divider"></div>
        <p class="service-desc">Clearer language. Sharper differentiation. Less filler. Especially for companies operating in crowded or highly technical categories.</p>
      </div>

      <div class="service-card">
        <div class="service-name">Content &amp; Editorial</div>
        <div class="service-divider"></div>
        <p class="service-desc">Newsletters, educational content, launch messaging, long-form writing, executive voice, and ongoing editorial direction. Built to sound like your company. Not like a content machine.</p>
      </div>

      <div class="service-card">
        <div class="service-name">Strategic Communication</div>
        <div class="service-divider"></div>
        <p class="service-desc">Launches, fundraising, category creation, shifts in market positioning, moments where the stakes are higher and the messaging actually matters.</p>
      </div>

    </div>
    <p class="services-note">Pricing is scoped to your stage and goals. <a href="/portfolio">See examples of our work</a> or <a href="#contact">get in touch</a> to talk through what makes sense.</p>
  </div>
</section>

<!-- ── PROOF POINTS ── -->
<section id="proof">
  <div class="container">
    <div class="section-label">Results</div>
    <h2 class="proof-heading">A few outcomes</h2>
    <p style="font-size:14px;color:var(--muted);margin-bottom:48px;">Read the thinking behind the work in our <a href="/blog" style="color:var(--accent);text-decoration:none;">blog</a>.</p>
    <div class="proof-rows">

      <div class="proof-row">
        <div class="proof-item">
          <div class="proof-stat">701%</div>
          <div class="proof-desc">Increase in site traffic</div>
        </div>
        <div class="proof-item">
          <div class="proof-stat">5,600+</div>
          <div class="proof-desc">Newsletter subscribers with engagement well above industry averages</div>
        </div>
        <div class="proof-item">
          <div class="proof-stat">2M+</div>
          <div class="proof-desc">Monthly impressions across managed channels</div>
        </div>
      </div>

      <div class="proof-row">
        <div class="proof-item">
          <div class="proof-stat">3,500+</div>
          <div class="proof-desc">Institutional readers across finance and emerging technology</div>
        </div>
        <div class="proof-item">
          <div class="proof-stat">300+</div>
          <div class="proof-desc">Educational and strategic articles published</div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ── -->
<section id="testimonials">
  <div class="container">
    <div class="section-label">Selected Perspectives</div>
    <div class="testimonials-grid">

      <div class="testimonial-card">
        <p class="testimonial-quote">John quickly understood the complexity of our business and translated it into a strategy that drove real growth.</p>
        <div class="testimonial-attribution">
          <div class="testimonial-name">Alex Gelbert</div>
          Founder &amp; CEO, Let There Be
        </div>
      </div>

      <div class="testimonial-card">
        <p class="testimonial-quote">A rare combination of strategic thinking and operational execution.</p>
        <div class="testimonial-attribution">
          <div class="testimonial-name">Benjamin Parr</div>
          CMO &amp; Growth Strategist
        </div>
      </div>

      <div class="testimonial-card">
        <p class="testimonial-quote">John made complex subjects easier to understand without oversimplifying them.</p>
        <div class="testimonial-attribution">
          <div class="testimonial-name">Aysenur Yükselal Aji</div>
          Marketing &amp; Growth Leader
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── ABOUT ── -->
<section id="about">
  <div class="container">
    <div class="about-grid">
      <div>
        <div class="section-label">About</div>
        <h2 class="about-heading">Built inside the companies doing the work.</h2>
        <p class="about-body">StoryArc came out of years spent inside fast-moving companies dealing with launches, market shifts, regulation, growth pressure, and the constant challenge of explaining complicated things clearly.<br /><br />That experience changes how you think about communication.<br /><br />A lot of messaging problems aren't really writing problems. They're clarity problems upstream. The company knows too much internally, so the outside language becomes vague without realizing it.<br /><br />That's usually where the work starts.</p>
      </div>
      <div class="about-right">
        <div class="about-detail">
          <div class="about-detail-label">Specialty</div>
          <div class="about-detail-value">Crypto infrastructure, exchanges, Bitcoin-native companies, institutional-facing protocols</div>
        </div>
        <div class="about-detail">
          <div class="about-detail-label">Experience</div>
          <div class="about-detail-value">8+ years operating inside crypto and fintech companies</div>
        </div>
        <div class="about-detail">
          <div class="about-detail-label">Approach</div>
          <div class="about-detail-value">Education before promotion. Narrative before tactics. Clarity before scale.</div>
        </div>
        <div class="about-detail">
          <div class="about-detail-label">Location</div>
          <div class="about-detail-value">Remote, working with teams globally</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── CONTACT ── -->
<section id="contact">
  <div class="container">
    <div class="contact-grid">
      <div>
        <div class="section-label">Contact</div>
        <h2 class="contact-heading">Let's talk.</h2>
        <p class="contact-sub">Tell us where you are and where you want to go. We'll figure out if we're the right fit, and if we are, we move fast.</p>
      </div>
      <div>
        <form id="contact-form" action="https://formspree.io/f/xvzyvpea" method="POST">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="Name" placeholder="Your name" autocomplete="name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="Email" placeholder="you@company.com" autocomplete="email" required />
          </div>
          <div class="form-group">
            <label for="company">Company</label>
            <input type="text" id="company" name="Company" placeholder="Your company" autocomplete="organization" />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="Message" placeholder="Tell us about your content goals…" autocomplete="off" required></textarea>
          </div>
          <div class="form-submit">
            <button type="submit" class="btn btn-accent">Send Message</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

</Base>

<script>
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  window.scrollTo(0, 0);

  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    });
    if (res.ok) {
      form.innerHTML = '<p style="color:#EF9F27;font-family:Inter,sans-serif;font-size:1rem;">Message sent — we\'ll be in touch soon.</p>';
    } else {
      btn.textContent = 'Send Message';
      btn.disabled = false;
      alert('Something went wrong. Please try again.');
    }
  });
</script>
