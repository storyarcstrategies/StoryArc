---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const posts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Base
  title="Blog | StoryArc Strategies"
  description="Writing on crypto, fintech, and the practice of clear communication by John Metais of StoryArc Strategies."
>

<div class="blog-hero">
  <div class="container">
    <div class="hero-eyebrow">Blog</div>
    <h1 class="hero-h1">Writing on crypto, fintech, and the practice of clear communication.</h1>
  </div>
</div>

<section id="articles" style="padding:80px 0;">
  <div class="container">
    <div class="articles-grid">

      {posts.length > 0 ? posts.map((post) => (
        <a class="article-card" href={`/blog/${post.slug}`}>
          <div class="article-card-content">
            <div class="article-category">{post.data.category}</div>
            <div class="article-title">{post.data.title}</div>
            <p class="article-excerpt">{post.data.description}</p>
            <div class="article-meta">
              <span>{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span class="article-read">Read →</span>
            </div>
          </div>
          {post.data.cardImage && (
            <div class="article-card-image">
              <img src={post.data.cardImage} alt="" />
            </div>
          )}
        </a>
      )) : (
        <div class="empty-state">
          <div class="empty-heading">First posts coming soon.</div>
          <p class="empty-sub">Writing on narrative strategy, content in crypto, and what separates companies that communicate clearly from the ones that don't.</p>
          <a class="btn btn-accent" href="/#contact">Get notified</a>
        </div>
      )}

    </div>
  </div>
</section>

</Base>

<script>
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  window.scrollTo(0, 0);
</script>
